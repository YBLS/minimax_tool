# ============================================================
#  MiniMax Tool — environment template
# ============================================================
# Copy this file to `.env` and fill in the values that differ from
# the defaults. Most settings have sensible development defaults
# baked in; production deployments should override at least the
# database password and provide an explicit MASTER_KEY.
#
#   cp .env.example .env
#
# Any value left commented out will use the default defined in
# `backend/app/config.py`.
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=9060
DEBUG=false

# --- Database ---
# Defaults match the bundled docker-compose.yml (postgres service).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=minimax_tool

# --- Storage ---
# Absolute path. Defaults to <project>/uploads.
UPLOAD_DIR=./uploads
# Absolute path to the built SPA. Defaults to <project>/backend/static.
STATIC_DIR=./backend/static

# --- External API ---
# Generous default — long-form video generation can take 60-180s.
REQUEST_TIMEOUT=180

# --- Secrets ---
# If unset, the backend auto-generates `.master_key` on first run.
# In production, supply this explicitly (Fernet URL-safe base64 key,
# 44 chars) and persist it in your secret manager:
#
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# MASTER_KEY=

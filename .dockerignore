# ============================================================
#  Docker build context — exclude files we don't want COPY'd
#  into the build context. Anything that is regenerated inside
#  the image (yarn cache, node_modules, PnP files, etc.) should
#  be listed here.
# ============================================================

# --- yarn 4 PnP (regenerated by `yarn install` in the image) ---
frontend/.yarn/
frontend/.pnp.cjs
frontend/.pnp.loader.mjs
frontend/install-state.gz

# --- node_modules (legacy npm) ---
frontend/node_modules/

# --- Editor / OS noise ---
.DS_Store
.idea/
.vscode/
*.swp
*~
*.bak
*.tmp

# --- Secrets / runtime state (NEVER bake into an image) ---
.master_key
.env
.env.*
config/database.yaml
config/database.local.yaml
uploads/

# --- Build outputs (regenerated during image build) ---
backend/static/assets/
backend/static/index.html
!backend/static/.gitkeep

# --- VCS / CI noise ---
.git/
.gitignore
.github/

# --- Local docs (not needed in the image) ---
docs/
*.md
!backend/**/*.md

# ============================================================
#  MiniMax Tool — local-only artifacts
#  DO NOT commit anything that could leak a real API key.
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Frontend ---
node_modules/
dist/
.vite/
*.tsbuildinfo

# --- Frontend build output (generated by `npm run build`) ---
backend/static/assets/
backend/static/index.html
# Keep the directory + a placeholder so the folder exists in the repo.
!backend/static/.gitkeep

# --- Secrets / runtime state (NEVER commit) ---
.master_key
.env
.env.*
uploads/*
!uploads/.gitkeep
!uploads/**/.gitkeep
backend/scripts/__pycache__/

# --- Database config (real values only — example file is tracked) ---
config/database.yaml
config/database.local.yaml
!config/database.yaml.example
!config/.gitkeep

# --- IDE / OS ---
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
*.swp
*~

# --- Logs ---
*.log
logs/
backend/logs/

# --- Test / smoke artifacts ---
.pytest_cache/
.coverage
htmlcov/
*.egg
.tox/

# --- Backups / scratch ---
*.bak
*.tmp
*.orig
.venv-*/
